# OpenAI — required. Powers all AI (advisor, chat, analysis).
# Free trial credit at https://platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Groq — optional fallback if OpenAI fails.
# Free at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Serper.dev — required only for "Find me jobs" mode.
# Without it, the jobs flow runs in Demo mode with mock listings.
# Free 2,500 searches/month at https://serper.dev
SERPER_API_KEY=your_serper_key_here
